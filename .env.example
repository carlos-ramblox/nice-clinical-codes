# API Keys (https://omophub.com, https://uts.nlm.nih.gov, https://console.anthropic.com)
OMOPHUB_API_KEY=your_omophub_api_key_here
UMLS_API_KEY=your_umls_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# OPENROUTER_API_KEY is only required if you call POST /api/baseline
# (the optional baseline LLM scoring endpoint). Leave unset otherwise.
OPENROUTER_API_KEY=your_openrouter_api_key_here

# App
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:3000

# ChromaDB
CHROMA_PERSIST_DIR=./chromadb_data
CHROMA_COLLECTION_NAME=clinical_codes

# Database
DATABASE_URL=sqlite:///./data/codes.db

# Pipeline
EMBEDDING_MODEL=NeuML/pubmedbert-base-embeddings
LLM_MODEL=claude-sonnet-4-20250514
LLM_SCORING_MODEL=claude-haiku-4-5-20251001
RETRIEVAL_TOP_K=50
MAX_CANDIDATES=100
CONFIDENCE_THRESHOLD=0.5
UMLS_EXPAND=yes

# HDR UK Phenotype Library -- anonymous public read access; no API key required.
# Consumed by the discovery sidebar (T34) and cross-reference panel (T35).
HDR_UK_BASE_URL=https://phenotypes.healthdatagateway.org
HDR_UK_TOP_K_PHENOTYPES=3
# When yes, an LLM scope-fit judge filters candidate phenotypes by clinical
# fit to the user query. Guards against HDR UK's full-text search returning
# conceptually wrong phenotypes (e.g. HIV -> paediatric Asthma).
HDR_UK_USE_JUDGE=yes
# Model id for the relevance judge. Default = LLM_SCORING_MODEL (Haiku 4.5).
HDR_UK_JUDGE_MODEL=claude-haiku-4-5-20251001

# Observability (optional)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=clinicalcodes-dev
# Set to https://eu.api.smith.langchain.com for EU-region projects; omit for US (default)
LANGCHAIN_ENDPOINT=
