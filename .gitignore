# OpenCodeCounts source files from NHS Digital (download at build time).
# Three upstreams: SNOMED primary care (tab-separated .txt) + HES
# inpatient ICD-10 / OPCS-4 (.csv).
data/raw/opencodecounts/*.csv
data/raw/opencodecounts/*.txt
data/raw/opencodecounts/*.zip
# NHS TRUD ICD-10 XML is subscription-licensed and not redistributed
data/icd10/*.xml
data/icd10/*.zip
data/opcs/*.xml
data/opcs/*.zip
